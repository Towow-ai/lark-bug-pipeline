# ~/.towow/.env.lark
# 飞书 Bug Pipeline 环境变量。复制到 ~/.towow/.env.lark 并填实际值。
# 不要 commit 到 git。

# === 必填（IM 群聊 @bot 默认路径） ===
# 飞书自建应用的 App ID / App Secret
# 从 https://open.feishu.cn/app 进入你的应用后在「凭证与基础信息」里拿
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bot 自己的 open_id —— 没有它 daemon 会把自己发的消息当成用户 bug 反复触发
# 第一次 @ bot 后会在 daemon 日志里打印 mentioned[].id，抄过来重启 daemon
LARK_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 你（管理员）的 open_id —— 触发 needs_nature 时会 @ 你
LARK_NATURE_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 日志级别 DEBUG / INFO / WARNING
LARK_LOG_LEVEL=INFO

# === 可选升级：多维表格集成 ===
# 默认不启用。只有当你想把每个 bug 也沉淀成一张结构化表格记录时才配置。
# 两个都填了才会启用 bitable 事件订阅和状态回写；留空就是纯 IM-only 模式。
# 配置方法见 docs/feishu-setup.md 「附录 A：可选升级多维表格」
# LARK_BUG_TABLE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxx
# LARK_BUG_TABLE_ID=tblxxxxxxxxxxxxx
# LARK_BUG_VIEW_ID=vewxxxxxxxxxxx
